# Quest Todo API Server Configuration
# Copy this file to .env and adjust values as needed

# ===================
# Server Configuration
# ===================

# Server host address (use 0.0.0.0 to accept external connections)
HOST=localhost

# Server port
PORT=8080

# HTTP timeouts (Go duration format: 1s, 5m, 1h30m)
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# ======================
# Database Configuration
# ======================

# Path to SQLite database file
# Relative paths are from where the server binary is executed
DB_PATH=./quest-todo.db

# =======================
# Service Layer Configuration
# =======================

# Validation limits
MAX_TITLE_LENGTH=200
MAX_DESCRIPTION_LENGTH=2000
MAX_BULK_SIZE=100

# Business rules (true/false)
REQUIRE_ALL_OBJECTIVES=false
AUTO_COMPLETE_ON_FULL_PROGRESS=true
ALLOW_PAST_DEADLINES=true

# Features (true/false)
ENABLE_CATEGORY_RESTRICTIONS=false
ENABLE_REWARD_SYSTEM=false

# ================================
# Router/Middleware Configuration
# ================================

# CORS allowed origins (comma-separated)
# Use "*" for all origins (development only!)
# Use specific domains for production
ALLOWED_ORIGINS=*

# Enable CORS middleware (true/false)
ENABLE_CORS=true

# Enable request/response logging (true/false)
# Disable in production for better performance
ENABLE_LOGGING=true

# ===================
# Example Configurations
# ===================

# Development (permissive)
# HOST=localhost
# PORT=8080
# ALLOWED_ORIGINS=*
# ENABLE_LOGGING=true

# Production (strict)
# HOST=0.0.0.0
# PORT=8080
# DB_PATH=/var/lib/quest-todo/data.db
# ALLOWED_ORIGINS=https://quest-todo.com,https://app.quest-todo.com
# ENABLE_LOGGING=false
# REQUIRE_ALL_OBJECTIVES=true
# MAX_BULK_SIZE=50

# Testing (restricted)
# PORT=9000
# DB_PATH=./test.db
# MAX_TITLE_LENGTH=100
# MAX_DESCRIPTION_LENGTH=500
# REQUIRE_ALL_OBJECTIVES=true
# AUTO_COMPLETE_ON_FULL_PROGRESS=false
